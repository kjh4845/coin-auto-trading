# Repo-local `.env` is auto-loaded when present.

# Runtime
APP_ENV=development
LOG_LEVEL=INFO
STRATEGY_MODE=best_pair_v1

# Binance
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_BASE_URL=wss://fstream.binance.com
BINANCE_FUTURES_TESTNET_BASE_URL=https://demo-fapi.binance.com
BINANCE_FUTURES_TESTNET_WS_BASE_URL=wss://fstream.binancefuture.com
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Optional legacy fallback names
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Trading scope
TRADING_SYMBOL=BTCUSDT
EXECUTION_TIMEFRAME=3m
MICRO_TIMEFRAME=5m
CONFIRMATION_TIMEFRAME=15m
MACRO_TIMEFRAME=1h
REGIME_TIMEFRAME=4h
ANCHOR_TIMEFRAME=1d
LIVE_START_LEVERAGE=5
SYSTEM_LEVERAGE_CAP=10
MAX_DAILY_LOSS_R=3.0
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_AFTER_LOSS_MINUTES=30
MAX_LONG_FUNDING_RATE=-0.0001
MIN_SHORT_FUNDING_RATE=0.0001
MIN_LONG_TAKER_BUY_RATIO=0.57
MAX_SHORT_TAKER_BUY_RATIO=0.43
MIN_MICRO_LONG_EMA_SPREAD_PCT=0.0015
MIN_MICRO_SHORT_EMA_SPREAD_PCT=0.00115
MIN_HIGHER_TF_EMA_SPREAD_PCT=0.001
MIN_VOLUME_RATIO_20=1.05
EXIT_POLICY=fixed_tp_time_stop
FIXED_TAKE_PROFIT_R=1.0
ATR_TRAIL_ACTIVATION_PROFIT_R=0.5
ATR_TRAIL_MIN_BARS=2

# Local model
LOCAL_MODEL_ID=google/gemma-4-E2B-it
LOCAL_MODEL_BASE=google/gemma-4-E2B-it
LOCAL_MODEL_PATH=/Users/your-user/llm/gemma4-e2b/model
LOCAL_MODEL_PYTHON=/Users/your-user/llm/gemma4-e2b/.venv/bin/python
LOCAL_MODEL_ENDPOINT=http://127.0.0.1:8080
LOCAL_MODEL_MPS_MAX_MEMORY=6GiB
LOCAL_MODEL_CPU_MAX_MEMORY=16GiB
AI_GATE_ENABLED=true
AI_GATE_FAIL_OPEN=false
AI_GATE_MIN_SETUP_QUALITY=0.55
AI_REDUCE_SIZE_FRACTION=0.5
AI_REQUEST_TIMEOUT_SECONDS=120.0
AI_MAX_TOKENS=192
AI_MAX_LATENCY_MS=15000
ALLOW_LONG_ENTRIES=false
ALLOW_SHORT_ENTRIES=true
